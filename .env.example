# Copy to .env and adjust as needed. Used by docker-compose.yml.

# Host ports to publish.
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Comma-separated list of origins the backend will accept CORS requests from.
# Only relevant when running backend/frontend as separate processes (e.g. local
# dev: vite on 5173, uvicorn on 8000). The Docker setup serves both behind one
# nginx origin, so this matters less there but is still honored.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Leave empty to use relative /api paths (correct for the Docker/nginx setup,
# where nginx proxies /api to the backend container on the same origin).
# Set to e.g. http://localhost:8000 only if serving the frontend separately
# from a backend on a different origin.
VITE_API_BASE_URL=
